# .env.local.example
# Salin file ini ke .env.local dan isi dengan nilai yang sebenarnya.
# JANGAN commit .env.local ke Git — sudah ada di .gitignore.

# ─── Firebase ────────────────────────────────────────────────────────────────
# Dapatkan dari: Firebase Console → Project Settings → Your Apps → Web App Config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Sentry (Opsional — monitoring error) ────────────────────────────────────
# Tanpa DSN ini, Sentry tidak aktif dan aplikasi tetap berjalan normal.
# Dapatkan dari: https://sentry.io → Project Settings → Client Keys → DSN
NEXT_PUBLIC_SENTRY_DSN=

# Untuk upload source maps ke Sentry (opsional, untuk stack trace readable di production)
# Dapatkan dari: https://sentry.io → Settings → Auth Tokens
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ─── E2E Testing (Opsional) ──────────────────────────────────────────────────
# Kredensial akun test untuk Playwright E2E — gunakan akun khusus test, bukan admin!
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=

# URL base untuk E2E test (default: http://localhost:3000)
# E2E_BASE_URL=http://localhost:3000
